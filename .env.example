APP_NAME="متجر العلامات"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# قاعدة البيانات — MySQL للإنتاج
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alamat_shop
DB_USERNAME=root
DB_PASSWORD=

# أو SQLite للتطوير السريع (احذف بيانات DB أعلاه واترك السطر التالي)
# DB_CONNECTION=sqlite

FILESYSTEM_DISK=public
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

AUDITING_ENABLED=true

# ─── المساعد الذكي ────────────────────────────────────────────────────
# احصل على مفتاح مجاني من: https://aistudio.google.com/apikey
AI_ENABLED=true
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.4
AI_RATE_PER_MIN=8
AI_CACHE_TTL=600
AI_MAX_MSG_LENGTH=500
AI_CONTEXT_PRODUCTS=20
AI_LOG_CHATS=true
AI_WELCOME="مرحباً! أنا مساعدك الذكي. أخبرني ماذا تبحث عنه وسأرشدك لأفضل المنتجات."

# (اختياري) مزوّدات بديلة
# GROQ_API_KEY=
# GROQ_MODEL=llama3-70b-8192
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3
