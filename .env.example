APP_NAME="متجر العلامات"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

# قاعدة البيانات — MySQL للإنتاج
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alamat_shop
DB_USERNAME=root
DB_PASSWORD=

# أو SQLite للتطوير السريع (احذف بيانات DB أعلاه واترك السطر التالي)
# DB_CONNECTION=sqlite

FILESYSTEM_DISK=public
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

AUDITING_ENABLED=true
