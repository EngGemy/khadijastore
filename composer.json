{
    "name": "alamat/shop-backend",
    "type": "project",
    "description": "متجر العلامات — Multi-brand shop backend (Laravel 12 + Filament 4)",
    "keywords": ["laravel", "filament", "multi-tenant", "ecommerce"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "facebook/php-business-sdk": "^25.0",
        "filament/filament": "4.*",
        "filament/spatie-laravel-media-library-plugin": "4.*",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9",
        "owen-it/laravel-auditing": "14.*",
        "spatie/laravel-medialibrary": "11.*",
        "spatie/laravel-permission": "6.*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "4.0",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
